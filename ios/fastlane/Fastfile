default_platform(:ios)

platform :ios do
  desc "Build and submit to TestFlight"
  lane :build_testflight do
    setup_ci if is_ci

    build_app(
      workspace: "TriandosChiro.xcworkspace",
      scheme: "TriandosChiro",
      configuration: "Release",
      derived_data_path: "build",
      destination: "generic/platform=iOS",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        teamID: "L82V95LG93",
        signingStyle: "automatic"
      },
      output_directory: "build",
      output_name: "TriandosChiro.ipa",
      skip_package_ipa: false,
      skip_package_pkg: true,
      xcargs: "DEVELOPMENT_TEAM=L82V95LG93 PRODUCT_BUNDLE_IDENTIFIER=com.triandoschiro.app -allowProvisioningUpdates"
    )

    upload_to_testflight(
      app_identifier: "com.triandoschiro.app",
      apple_id: ENV["APPLE_ID"],
      app_password: ENV["FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD"],
      skip_waiting_for_build_processing: true,
      skip_submission: false,
      team_id: "L82V95LG93",
      verbose: false
    )

    puts "✅ Build submitted to TestFlight successfully!"
  end

  desc "Build without uploading"
  lane :build_only do
    setup_ci if is_ci

    build_app(
      workspace: "TriandosChiro.xcworkspace",
      scheme: "TriandosChiro",
      configuration: "Release",
      derived_data_path: "build",
      destination: "generic/platform=iOS",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        teamID: "L82V95LG93",
        signingStyle: "automatic"
      },
      output_directory: "build",
      output_name: "TriandosChiro.ipa",
      skip_package_ipa: false,
      xcargs: "DEVELOPMENT_TEAM=L82V95LG93 PRODUCT_BUNDLE_IDENTIFIER=com.triandoschiro.app -allowProvisioningUpdates"
    )
  end

  error do |lane, exception|
    puts "❌ Build failed: #{exception}"
  end
end
