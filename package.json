{
  "name": "triandos-chiro-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "react-native start",
    "ios": "react-native run-ios --simulator='iPhone 15'",
    "android": "react-native run-android",
    "test": "jest",
    "lint": "eslint . --ext .ts,.tsx",
    "build:ios": "cd ios && xcodebuild -workspace TriandosChiro.xcworkspace -scheme TriandosChiro -configuration Release -derivedDataPath build",
    "clean": "rm -rf node_modules && npm install"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.75.4",
    "@react-native-firebase/app": "^21.2.0",
    "@react-native-firebase/auth": "^21.2.0",
    "@react-native-firebase/firestore": "^21.2.0",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/stack": "^6.4.0",
    "react-native-screens": "^3.31.1",
    "react-native-safe-area-context": "^4.10.5",
    "react-native-gesture-handler": "^2.16.0",
    "react-native-reanimated": "^3.10.1",
    "react-native-calendars": "^1.1504.4",
    "axios": "^1.7.2",
    "date-fns": "^3.6.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "typescript": "^5.3.3",
    "@react-native-firebase/cli": "^21.2.0",
    "jest": "^29.7.0",
    "@testing-library/react-native": "^12.4.3",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0"
  }
}
