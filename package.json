{
  "name": "triandos-chiro-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "react-native start",
    "ios": "react-native run-ios --simulator='iPhone 15'",
    "android": "react-native run-android",
    "test": "jest",
    "lint": "eslint . --ext .ts,.tsx",
    "build:ios": "cd ios && xcodebuild -workspace TriandosChiro.xcworkspace -scheme TriandosChiro -configuration Release -derivedDataPath build",
    "clean": "rm -rf node_modules && npm install"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.75.4",
    "@react-native-firebase/app": "^18.0.0",
    "@react-native-firebase/auth": "^18.0.0",
    "@react-native-firebase/firestore": "^18.0.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/bottom-tabs": "^6.5.0",
    "@react-navigation/stack": "^6.3.0",
    "react-native-screens": "^3.27.0",
    "react-native-safe-area-context": "^4.8.0",
    "react-native-gesture-handler": "^2.14.0",
    "axios": "^1.6.0",
    "date-fns": "^2.30.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.0",
    "typescript": "^5.3.0",
    "jest": "^29.7.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0"
  }
}
